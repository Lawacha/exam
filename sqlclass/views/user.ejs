<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1>users</h1>
    <form action="http://localhost:8080/user/new">
        <input type="submit" value="add new id">
    </form>
    <form action="http://localhost:8080/user?_method=delete " method="post" >
        <input type="submit" value="delete all">
    </form>
   <div class="container">
<div class="heading">
        <div class="id"><h3>ID</h3></div>
        <div class="username"><h3>Username</h3></div>
        <div class="email"><h3>Email</h3></div>
    </div>
 <% for (let index = 0; index < id.length; index++) { %>
       <div class="row">
      <div class="id">
          <%= id[index] %>
      </div>
       <div class="username">
         <%= username[index] %>
       </div>
        <div class="email">
            <%= email[index] %>
            
        </div>
        <a href="http://localhost:8080/user/<%=id[index]%>/edit">Edit</a>
        <form action="http://localhost:8080/user/<%=id[index]%>/delete" >
            <input type="submit" value="delete">
        </form>
       </div>
       
        
 <%   } %>

   </div>
    
</body>
</html>