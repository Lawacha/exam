<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="style.css">
    <style>
        .inp{
    width: 300px;
    height: 30px;
}
.textar{
    width: 500px;
    height: 80px;
}
